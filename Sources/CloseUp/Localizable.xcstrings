    "Stable ships tagged releases. Beta tracks the nightly build — newer features, less tested.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stabil stammt aus veröffentlichten Versionen, Beta folgt dem Nightly-Build — neue Funktionen früher, aber weniger getestet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El canal estable proviene de versiones publicadas; el canal beta sigue la compilación nocturna: novedades antes, pero menos probadas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le canal stable provient des versions publiées ; le canal bêta suit la version nocturne — nouveautés plus tôt, mais moins testées."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "安定版はタグ付きリリース、ベータ版はナイトリービルドを追跡します——新機能をいち早く、ただしテストは少なめ。"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O canal estável vem de versões publicadas; o beta acompanha a compilação noturna — novidades antes, mas menos testadas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стабильный канал — это релизы с тегами, бета-канал отслеживает ночные сборки — новые функции раньше, но меньше тестирования."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "稳定版来自正式发布，测试版跟踪每日构建——功能更新，但测试较少。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "穩定版來自正式發布，測試版追蹤每日建置——功能更新，但測試較少。"
          }
        }
      }
    },
    "Update checks are unavailable in development builds.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Updateprüfung ist in Entwicklungs-Builds nicht verfügbar."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La comprobación de actualizaciones no está disponible en versiones de desarrollo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La recherche de mises à jour n'est pas disponible dans les versions de développement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "開発ビルドではアップデートの確認を利用できません。"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A verificação de atualizações não está disponível em versões de desenvolvimento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
