    "Active only while Mission Control is open.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur aktiv, wenn Mission Control geöffnet ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo activo mientras Mission Control está abierto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Actif uniquement lorsque Mission Control est ouvert."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mission Control が開いているときのみ有効です。"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ativo somente enquanto o Mission Control estiver aberto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Активно только при открытом Mission Control."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅在调度中心打开时有效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅在調度中心開啟時有效。"
          }
        }
      }
    },
