    "CloseUp needs Accessibility access to read the windows in Mission Control and to close, minimize, hide, or quit them. It never records your screen.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "CloseUp benötigt Bedienungshilfen-Zugriff, um die Fenster in Mission Control zu lesen und sie zu schließen, zu minimieren, auszublenden oder zu beenden. Der Bildschirm wird niemals aufgezeichnet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "CloseUp necesita acceso de accesibilidad para leer las ventanas de Mission Control y cerrarlas, minimizarlas, ocultarlas o salir de ellas. Nunca graba tu pantalla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "CloseUp a besoin de l’accès à l’accessibilité pour lire les fenêtres de Mission Control et les fermer, réduire, masquer ou quitter. Il n’enregistre jamais votre écran."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CloseUp は、Mission Control 内のウインドウを読み取り、閉じる・しまう・非表示・終了するためにアクセシビリティ権限を必要とします。画面を録画することは一切ありません。"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O CloseUp precisa de acesso de acessibilidade para ler as janelas do Mission Control e fechá-las, minimizá-las, ocultá-las ou encerrá-las. Ele nunca grava a sua tela."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "CloseUp нужен доступ к универсальному доступу, чтобы считывать окна в Mission Control и закрывать, сворачивать, скрывать или завершать их. Он никогда не записывает ваш экран."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "CloseUp 需要“辅助功能”权限来读取调度中心中的窗口，并对其执行关闭、最小化、隐藏或退出操作。它绝不会录制你的屏幕。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "CloseUp 需要「輔助使用」權限來讀取調度中心中的視窗，並對其執行關閉、縮到最小、隱藏或結束操作。它絕不會錄製你的螢幕。"
          }
        }
      }
    },
    "CloseUp updates automatically using a signed, notarized release feed.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "CloseUp wird automatisch über einen signierten, notarisierten Release-Feed aktualisiert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "CloseUp se actualiza automáticamente mediante un canal de versiones firmado y notarizado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "CloseUp se met à jour automatiquement via un flux de publication signé et notarisé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CloseUp は、署名・公証済みのリリースフィードを使用して自動的にアップデートします。"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "CloseUp se atualiza automaticamente usando um feed de versões assinado e notarizado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "CloseUp обновляется автоматически через подписанный и нотаризованный канал выпусков."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "CloseUp 使用经过签名和公证的发布源自动更新。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "CloseUp 使用經過簽名和公證的發佈來源自動更新。"
          }
        }
      }
    },
