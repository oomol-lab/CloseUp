    "Choose which controls appear on each window in Mission Control.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie, welche Steuerelemente in Mission Control auf jedem Fenster angezeigt werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige qué controles aparecen en cada ventana en Mission Control."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez les contrôles qui apparaissent sur chaque fenêtre dans Mission Control."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mission Control の各ウインドウに表示するコントロールを選択します。"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha quais controles aparecem em cada janela no Mission Control."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите элементы управления, отображаемые на каждом окне в Mission Control."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择在调度中心中每个窗口上显示的控制按钮。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇在調度中心中每個視窗上顯示的控制按鈕。"
          }
        }
      }
    },
